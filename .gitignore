# Environment & Secrets
.env
*.env.local

# Logs
*.log
logs/

# PID files
*.pid

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/
env/
.env.bak/

# Data files (keep structure, ignore contents)
data/*
!data/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Test files (optional - remove if you want to track tests)
test_*.py
!test_connection.py

# Temporary files
*.tmp
*.temp
*.bak

# Streamlit
.streamlit/secrets.toml

# .NET build artifacts & published binaries
installer/publish-native/
installer/publish/
installer/**/bin/
installer/**/obj/
*.exe

