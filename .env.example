# ============================================
# HikVision Bulletproof - Configuration
# ============================================
# Copy this file to .env and update with your values
# cp .env.example .env

# --------------------------------------------
# Hikvision Device Configuration
# --------------------------------------------
DEVICE_IP=192.168.1.128
DEVICE_USER=admin
DEVICE_PASS=your_device_password_here

# Optional: Device identifier for multi-device setups
DEVICE_ID=door1

# --------------------------------------------
# Database Configuration (MySQL/MariaDB)
# --------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hikvision
DB_USER=root
DB_PASS=your_database_password_here

# --------------------------------------------
# Webhook Configuration (Optional)
# --------------------------------------------
# Your backend URL to receive events
WEBHOOK_URL=https://your-backend.com/api/hikvision/events

# API key for webhook authentication (sent as X-API-Key header)
WEBHOOK_API_KEY=your_api_key_here

# --------------------------------------------
# Bridge Settings
# --------------------------------------------
# Polling interval in seconds (default: 2)
POLL_INTERVAL=2

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=hikvision_bridge.log

# --------------------------------------------
# Advanced Settings
# --------------------------------------------
# Data retention in days (for cleanup jobs)
DATA_RETENTION_DAYS=90

# Enable auto backup of events
AUTO_BACKUP_ENABLED=true

